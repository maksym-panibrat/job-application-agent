{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run pytest*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run ruff format --check*)",
      "Bash(uv run ruff format*)",
      "Bash(uv run alembic current)",
      "Bash(uv run alembic heads)",
      "Bash(uv run alembic history*)",
      "Bash(uv run alembic upgrade head)",
      "Bash(uv run alembic downgrade*)",
      "Bash(uv run alembic revision*)",
      "Bash(uv run mypy*)",
      "Bash(uv sync*)",
      "Bash(uv lock)",
      "Bash(uv run uvicorn*)",
      "Bash(uv run pre-commit run*)",
      "Bash(cd frontend && npm install)",
      "Bash(cd frontend && npm ci)",
      "Bash(cd frontend && npm run build)",
      "Bash(cd frontend && npm run dev)",
      "Bash(cd frontend && npm test*)",
      "Bash(cd frontend && npm run test:e2e*)",
      "Bash(cd frontend && npx playwright*)",
      "Bash(cd frontend && npx tsc --noEmit)",
      "Bash(docker compose up -d db)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-edit.sh",
            "timeout": 60,
            "statusMessage": "Validating edit..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "python-development@claude-code-workflows": true,
    "javascript-typescript@claude-code-workflows": true,
    "llm-application-dev@claude-code-workflows": true,
    "comprehensive-review@claude-code-workflows": true,
    "api-testing-observability@claude-code-workflows": true,
    "backend-api-security@claude-code-workflows": true,
    "database-migrations@claude-code-workflows": true,
    "cicd-automation@claude-code-workflows": true
  }
}
